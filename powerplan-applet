#!/usr/bin/env python3
import gi
gi.require_version('Gtk', '3.0')
from gi.repository import Gtk
import subprocess
import json
import os
import sys

CONFIG_PATH = os.path.expanduser("~/.config/powerplan.json")

DEFAULT_CONFIG = {
    "performance": {
        "label": "Performance",
        "stapm_limit": 15000,
        "fast_limit": 30000,
        "slow_limit": 25000
    },
    "balanced": {
        "label": "Balanced",
        "stapm_limit": 12000,
        "fast_limit": 18000,
        "slow_limit": 15000
    },
    "powersaver": {
        "label": "Power Saver",
        "stapm_limit": 8000,
        "fast_limit": 12000,
        "slow_limit": 10000
    }
}

def ensure_config():
    if not os.path.exists(CONFIG_PATH):
        os.makedirs(os.path.dirname(CONFIG_PATH), exist_ok=True)
        with open(CONFIG_PATH, "w") as f:
            json.dump(DEFAULT_CONFIG, f, indent=2)
        print(f"Created default config at {CONFIG_PATH}")

def load_config():
    ensure_config()
    with open(CONFIG_PATH) as f:
        return json.load(f)

def build_args(cfg):
    return f"--stapm-limit={cfg['stapm_limit']} --fast-limit={cfg['fast_limit']} --slow-limit={cfg['slow_limit']}"

profiles = []
plan_keys = []
current_idx = 0

def save_config(config):
    with open(CONFIG_PATH, "w") as f:
        json.dump(config, f, indent=2)

def apply(idx):
    global current_idx
    current_idx = idx
    key = plan_keys[idx]
    subprocess.run(["sudo", "ryzenadj"] + build_args(profiles[key]).split(), check=False)
    icon.set_tooltip_text(f"Power: {profiles[key]['label']}")

def menu(ic, button, time):
    m = Gtk.Menu()
    for i, key in enumerate(plan_keys):
        item = Gtk.MenuItem(label=profiles[key]["label"])
        if i == current_idx:
            item.set_sensitive(False)
        item.connect("activate", lambda _, n=i: apply(n))
        m.append(item)
    m.append(Gtk.SeparatorMenuItem())
    q = Gtk.MenuItem(label="Quit")
    q.connect("activate", lambda _: Gtk.main_quit())
    m.append(q)
    m.show_all()
    m.popup(None, None, None, ic, button, time)

def cycle(ic):
    apply((current_idx + 1) % len(plan_keys))

config = load_config()
profiles = config
plan_keys = list(profiles.keys())

icon = Gtk.StatusIcon()
icon.set_from_icon_name("computer")
first = profiles[plan_keys[0]]
icon.set_tooltip_text(f"Power: {first['label']}")
apply(0)
icon.connect("popup-menu", menu)
icon.connect("activate", cycle)
Gtk.main()
